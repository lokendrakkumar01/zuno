# MongoDB Connection
MONGODB_URI=mongodb+srv://your-connection-string
# Legacy alias still supported
MONGO_URI=

# JWT Secret
JWT_SECRET=your-jwt-secret-here

# Node Environment
NODE_ENV=development

# Port
PORT=5000

# Public app URLs
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
# Optional self-ping URL for keep-alive; on Render this can usually be omitted because RENDER_EXTERNAL_URL is available
BACKEND_URL=
# Optional comma-separated extra origins for CORS/socket access
CORS_ORIGINS=http://localhost:3000,http://localhost:4173

# Cloudinary Configuration (REQUIRED for production - media storage)
# Sign up at https://cloudinary.com and get your credentials
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Cloudinary Live Streaming (REQUIRED for live stream playback + ingest)
# Use the values from Cloudinary Live Streams dashboard. One channel supports one concurrent broadcast.
CLOUDINARY_STREAM_CLOUD_NAME=your-cloud-name
CLOUDINARY_STREAM_KEY=your-stream-key
CLOUDINARY_STREAM_RTMP_URL=rtmp://live.cloudinary.com/streams
CLOUDINARY_STREAM_HLS_URL=https://res.cloudinary.com/your-cloud/video/live/your-stream_hls.m3u8
# Optional if it can be derived from HLS URL above
CLOUDINARY_STREAM_HLS_PUBLIC_ID=your-stream_hls
# Optional if cloud name + HLS public id are available
CLOUDINARY_STREAM_PLAYER_URL=https://player.cloudinary.com/embed/?cloud_name=your-cloud&public_id=your-stream_hls&profile=cld-live-streaming

# Optional Google auth
GOOGLE_CLIENT_ID=

# Optional email service
EMAIL_USER=
EMAIL_PASS=
