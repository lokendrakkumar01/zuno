{
  "name": "zuno-backend",
  "version": "1.0.0",
  "description": "Zuno real-time social and streaming backend",
  "main": "server.js",
  "scripts": {
    "preinstall": "node scripts/preinstall.js 2>/dev/null || true",
    "start": "node server.js",
    "start:safe": "node scripts/ensure-runtime-deps.js && node --max-old-space-size=350 --expose-gc server.js",
    "dev": "nodemon server.js",
    "build": "node scripts/clean-install.js"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cloudinary": "1.41.3",
    "compression": "1.8.1",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.21.2",
    "express-mongo-sanitize": "2.2.0",
    "express-rate-limit": "7.1.5",
    "express-validator": "7.3.2",
    "google-auth-library": "10.6.2",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.2",
    "mongodb": "6.2.0",
    "mongoose": "8.0.3",
    "multer": "1.4.5-lts.1",
    "multer-storage-cloudinary": "4.0.0",
    "nodemailer": "8.0.5",
    "passport": "0.7.0",
    "passport-google-oauth20": "2.0.0",
    "socket.io": "4.8.1",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "nodemon": "3.0.2"
  }
}
