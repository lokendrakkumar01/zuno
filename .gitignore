# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/
admin-panel/node_modules/

# Environment files
.env
.env.*
.env.local
.env.production
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*
admin-panel/.env
admin-panel/.env.*

# Build outputs — never commit built artifacts
.dist/
admin-panel/.dist/
frontend/dist/

# Logs
logs/
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Uploads (stored locally during dev, served by Cloudinary in prod)
backend/uploads/*
!backend/uploads/.gitkeep

# Vite temporary config timestamp files
frontend/vite.config.js.timestamp-*

# Capacitor Android build (generated - do not commit)
frontend/android/

# APK binaries and keystore — NEVER commit these
*.apk
*.apk.idsig
*.jks

# Test and debug scripts (not needed in production)
backend/api_test*.js
backend/test_*.js
backend/db_debug.js
backend/generate_token.js
